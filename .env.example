# App
APP_ENV=development
AUTH_REQUIRED=false
ALLOWLIST_EMAILS=you@growingmonk.com
PORT=3001

# Auth — generate NEXTAUTH_SECRET with: openssl rand -hex 32
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=

# Database
DB_PROVIDER=json                          # json | firestore
LOCAL_DB_PATH=.data/client-hub.json
FIRESTORE_DATABASE_ID=client-hub

# GCP
GOOGLE_CLOUD_PROJECT=growingmonk-495400
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_MAPS_API_KEY=

# Google OAuth — for GBP per-client OAuth flow
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/integrations/gbp/oauth/callback
DEFAULT_GBP_PLACE_ID=

# Google Ads — one developer token for the whole agency
GOOGLE_ADS_DEVELOPER_TOKEN=

# AI — Google Gemini (get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_API_KEY_SECRET=gemini-api-key     # Secret Manager secret name (Cloud Run fallback)
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# AI — Anthropic Claude (get key at https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# WhatsApp Business Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEEKLY_REPORT_TEMPLATE=weekly_report
WHATSAPP_REVIEW_REQUEST_TEMPLATE=review_request

# Scheduler — generate with: openssl rand -hex 32
SCHEDULER_SECRET=

# MonkAudit source prefill (internal tool path)
MONKAUDIT_DB_PATH=../monkaudit-v2/.data/growingmonk-sales-os.json
